# Frontend Dockerfile
FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY bun.lockb ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Expose port
EXPOSE 5173

# Set environment
ENV NODE_ENV=development

# Start development server
CMD ["npm", "run", "dev", "--", "--host"]
